{
  "type": "object",
  "required": ["website", "topics", "pc", "cycles"],
  "properties": {
    "website": {
      "type": "object",
      "required": ["url", "available", "archive"],
      "properties": {
        "url": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "available": {
          "type": "boolean"
        },
        "archive": {
          "type": ["string", "null"],
          "format": "uri"
        }
      },
      "additionalProperties": false
    },

    "proceedings": {
      "type": "object",
      "required": ["url", "open"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "open": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },

    "topics": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "minProperties": 1,
            "maxProperties": 1,
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ]
      }
    },

    "pc": {
      "type": "array",
      "items": {
        "type": "object",
        "minProperties": 1,
        "maxProperties": 1,
        "additionalProperties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },

    "cycles": {
      "type": "array",
      "items": {
        "type": "object",
        "minProperties": 1,
        "maxProperties": 1,
        "additionalProperties": {
          "type": "object",
          "properties": {
            "abstract": { "type": "string" },
            "submission": { "type": "string" },
            "early-reject": { "type": "string" },
            "rebuttal-start": { "type": "string" },
            "rebuttal-end": { "type": "string" },
            "acceptance": { "type": "string" },
            "shepherding-submission": { "type": "string" },
            "shepherding-acceptance": { "type": "string" },
            "revision-submission": { "type": "string" },
            "revision-acceptance": { "type": "string" },
            "camera-ready": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    },

    "anonymous": { "type": "boolean" },
    "conflicts": { "type": "boolean" },
    "ethics-discussion": { "type": "boolean" },
    "meta-review": { "type": "boolean" },
    "cves": { "type": "boolean" },
    "genai": { "type": "boolean" }
  },

  "additionalProperties": false
}
